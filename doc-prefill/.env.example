# Copy this file to ".env" and fill in your key. The .env file is loaded
# automatically by the app and pipeline — no need to `export` anything.
#
#   cp .env.example .env
#   # then edit .env and paste your real key

# Required for REAL extraction (without it, the offline mock runs)
OPENAI_API_KEY=sk-your-key-here

# Optional: API key for the production server (api/api_server.py)
# Leave blank or remove to disable authentication entirely
# API_KEY=your-secret-api-key-here

# Optional tunables (defaults shown)
PREFILL_MODEL=gpt-4o-2024-08-06
PREFILL_CONCURRENCY=5
PREFILL_MAX_RETRIES=4
PREFILL_REVIEW_CONF=0.7
