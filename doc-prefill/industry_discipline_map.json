{
  "_meta": {
    "version": "1.0.0",
    "description": "Industry-to-science-discipline keyword mapping for TaxVantage Stage 9 AI classification. Agent scans uploaded project documents, matches keywords against each discipline's keyword_clusters, and auto-checks disciplines that meet the match_threshold.",
    "usage": "For each project's uploaded files, run keyword frequency scan per discipline. If matched_keywords >= match_threshold, mark discipline as auto_checked: true. Present all disciplines for the client's industry with auto_checked state pre-selected. Client can add or remove.",
    "match_threshold_default": 2,
    "match_logic": "Case-insensitive. Match on whole word or compound phrase. Count unique keyword hits, not total occurrences. If any single keyword from a cluster appears 2+ times across all project documents, that keyword counts as one hit."
  },

